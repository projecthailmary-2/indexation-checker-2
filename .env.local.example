# Copy this file to ".env.local" for local development and fill in the values.
# On Render, set these same three under the service's Environment tab.

# The service account's email (looks like name@project.iam.gserviceaccount.com)
GOOGLE_SERVICE_ACCOUNT_EMAIL=

# The service account's private key. Keep the quotes. Paste it all on one line
# with the line breaks written as \n (the app converts them back automatically).
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# The ID from your Google Sheet's URL:
# https://docs.google.com/spreadsheets/d/THIS_PART/edit
# (For testing, use the ID of your COPY of the workbook — not the live one.)
GOOGLE_SHEET_ID=

# The tab the app reads the site list from and writes results back into.
# Defaults to "TRACKING- MAINTENANCE/REHAB" if left blank.
GOOGLE_TRACKING_TAB=TRACKING- MAINTENANCE/REHAB
